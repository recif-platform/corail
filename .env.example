# ===========================================
# Corail Runtime — Environment Variables
# ===========================================
# Copy to .env and adjust values for your environment.

# --- Environment ---
CORAIL_ENV=dev  # dev | test | prod

# --- Server ---
CORAIL_PORT=8000
CORAIL_HOST=0.0.0.0

# --- Database ---
CORAIL_DATABASE_URL=postgresql+asyncpg://recif:recif_dev@localhost:5432/recif
CORAIL_DB_SCHEMA=corail

# --- gRPC ---
CORAIL_GRPC_PORT=50051
CORAIL_RECIF_GRPC_ADDR=recif-api:50052

# --- mTLS (Récif communication) ---
CORAIL_MTLS_CERT_PATH=
CORAIL_MTLS_KEY_PATH=

# --- Authentication ---
CORAIL_JWT_PUBLIC_KEY=  # Shared public key for JWT validation (Récif-issued tokens)

# --- Logging ---
CORAIL_LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
CORAIL_LOG_FORMAT=json  # json | text

# --- Agent ---
CORAIL_AGENT_NAME=my-agent
CORAIL_CHANNEL=rest                  # rest | websocket | slack | cli
CORAIL_STRATEGY=agent-react          # agent-react | simple | rag
CORAIL_MODEL_TYPE=stub               # stub | ollama | openai | anthropic | google-ai | vertex-ai | bedrock
CORAIL_MODEL_ID=stub-echo            # Model ID for the selected provider
CORAIL_SYSTEM_PROMPT=""
CORAIL_STORAGE=memory                # memory | postgresql

# --- LLM Provider Keys (set the one matching CORAIL_MODEL_TYPE) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GOOGLE_CLOUD_PROJECT=my-project-123
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434

# --- Tools & Skills (JSON) ---
# CORAIL_TOOLS='[{"name":"web_search","type":"builtin"}]'
# CORAIL_SKILLS='["agui-render"]'
# CORAIL_KNOWLEDGE_BASES='[]'

# --- Evaluation ---
# MLFLOW_TRACKING_URI=http://localhost:5000
# RECIF_EVAL_SAMPLE_RATE=0.10
# RECIF_JUDGE_MODEL=openai:/gpt-4o-mini

# --- Suggestions ---
# CORAIL_SUGGESTIONS_PROVIDER=llm
# CORAIL_SUGGESTIONS='["What can you do?"]'
